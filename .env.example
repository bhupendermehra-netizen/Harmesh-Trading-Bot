# Exchange API Keys (replace with real keys)
EXCHANGE_API_KEY=your_api_key_here
EXCHANGE_SECRET=your_api_secret_here
EXCHANGE_PASSPHRASE=  # For coinbasepro/kraken if needed

# Flask config
FLASK_SECRET=replace-with-random-secret
FLASK_ENV=development
FLASK_PORT=5500

# Trading defaults
SYMBOLS=BTC/USDT,ETH/USDT
TIMEFRAME=1h
MAX_OPEN_TRADES=3
