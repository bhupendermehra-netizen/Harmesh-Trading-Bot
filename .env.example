# Harmesh Trading System — Environment Variables
# Copy this to .env and fill in your exchange API keys
# cp .env.example .env

# Exchange API Keys (required for live trading, optional for paper)
EXCHANGE_NAME=binance
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=

# Paper Trading
PAPER_CAPITAL=1000.0
PAPER_MIN_TRADES=200
PAPER_MIN_DAYS=7

# Live Trading (only used after Phase 1 thresholds met)
LIVE_CAPITAL=100.0
LIVE_MAX_RISK=0.02

# System
LOG_LEVEL=INFO
TICK_INTERVAL=300
